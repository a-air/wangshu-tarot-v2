# 望舒塔罗 v2 — 环境变量模板
# 复制此文件为 .env 并填入真实值

# DashScope AI API Key（阿里云通义千问）
DASHSCOPE_API_KEY=sk-your-api-key-here

# DashScope 模型名称
DASHSCOPE_MODEL=qwen-plus

# DashScope API 基础地址
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# SQLite 数据库文件路径
DATABASE_PATH=wangshu_tarot.db

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=false
